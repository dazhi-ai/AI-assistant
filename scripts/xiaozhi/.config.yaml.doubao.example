server:
  ip: 0.0.0.0
  port: 8000
  http_port: 8003
  websocket: ws://你的服务器IP:8000/xiaozhi/v1/

selected_module:
  LLM: DoubaoLLM
  ASR: DoubaoASR
  TTS: HuoshanDoubleStreamTTS
  Intent: function_call

LLM:
  DoubaoLLM:
    type: openai
    base_url: https://ark.cn-beijing.volces.com/api/v3
    model_name: doubao-1-5-pro-32k-250115
    api_key: 你的ARK_API_KEY

ASR:
  DoubaoASR:
    type: doubao
    appid: 你的VOLC_APP_ID
    access_token: 你的VOLC_ACCESS_TOKEN
    cluster: volcengine_input_common

TTS:
  HuoshanDoubleStreamTTS:
    type: huoshan_double_stream
    ws_url: wss://openspeech.bytedance.com/api/v3/tts/bidirection
    appid: 你的VOLC_APP_ID
    access_token: 你的VOLC_ACCESS_TOKEN
    resource_id: seed-tts-2.0
    speaker: zh_female_wanwanxiaohe_moon_bigtts
    enable_ws_reuse: true

Intent:
  function_call:
    type: function_call
    functions:
      - get_weather
      - play_music

plugins:
  get_weather:
    api_key: 你的QWEATHER_API_KEY
    api_host: 你的QWEATHER_API_HOST
    default_location: 广州
